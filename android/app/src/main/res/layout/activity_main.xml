<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#14142A"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/ic_launcher_foreground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="CelestiaFlow"
                android:textColor="#00B4D8"
                android:textSize="18dp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCustomize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#333"
            android:text="⚙️"
            android:textSize="18dp" />
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Liquid Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A2E"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp">

            <com.celestiaflow.LiquidOrbView
                android:id="@+id/liquidOrb"
                android:layout_width="180dp"
                android:layout_height="180dp" />

            <TextView
                android:id="@+id/liquidName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Water 💧"
                android:textColor="#FFF"
                android:textSize="28dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Surprise Button -->
        <Button
            android:id="@+id/btnSurprise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="#9D4EDD"
            android:padding="20dp"
            android:text="🎲 Surprise Me"
            android:textColor="#FFF"
            android:textSize="18dp" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A0A1A"
        android:gravity="center"
        android:paddingVertical="15dp">

        <Button
            android:id="@+id/btnGames"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#00000000"
            android:text="🎮\nGames"
            android:textColor="#888"
            android:textSize="12dp" />

        <Button
            android:id="@+id/btnWidgets"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#00000000"
            android:text="📊\nWidgets"
            android:textColor="#888"
            android:textSize="12dp" />

        <Button
            android:id="@+id/btnStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#00000000"
            android:text="🏆\nStats"
            android:textColor="#888"
            android:textSize="12dp" />

        <Button
            android:id="@+id/btnCustomizeNav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#00000000"
            android:text="⚙️\nCustomize"
            android:textColor="#00B4D8"
            android:textSize="12dp" />
    </LinearLayout>

</LinearLayout>